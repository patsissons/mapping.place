# Shared app gate for NextAuth credentials sign-in. Set either AUTH_SECRET or
# NEXTAUTH_SECRET.
AUTH_SECRET=

# only needed for local development, should be set to http://localhost:3000
NEXTAUTH_URL=

# credentials for the shared app gate
APP_AUTH_USERNAME=
APP_AUTH_PASSWORD=

# Required to hydrate Google Place IDs on the server and in the internal place
# hydration API route.
GOOGLE_PLACES_API_KEY=
