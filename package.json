{
  "name": "mapping.place",
  "description": "Plan a trip with your friends using Google Maps.",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": "18"
  },
  "author": {
    "name": "Pat Sissons",
    "email": "patricksissons@gmail.com",
    "url": "https://github.com/patsissons"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/patsissons/mapping.place.git"
  },
  "bugs": {
    "url": "https://github.com/patsissons/mapping.place/issues"
  },
  "homepage": "https://mapping.place",
  "license": "MIT",
  "scripts": {
    "conf": "yarn run conf:link && yarn run conf:env",
    "conf:link": "test -f .vercel/project.json || vercel link",
    "conf:env": "./scripts/setup-env.sh",
    "conf:clean": "rm -rf .vercel .env*.local",
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "test": "npm run test:integration && npm run test:unit",
    "svelte:check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "svelte:check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "prettier:check": "prettier --plugin-search-dir . --check .",
    "prettier:format": "prettier --plugin-search-dir . --write .",
    "lint:prettier": "pnpm run prettier:check",
    "lint:style": "stylelint 'src/**/*.{css,svelte}'",
    "lint:es": "svelte-kit sync && eslint .",
    "lint:es:summary": "pnpm lint:es --format summary",
    "lint": "yarn lint:prettier && yarn lint:style && yarn lint:es",
    "test:integration": "playwright test",
    "test:unit": "vitest",
    "validate": "tsc --noEmit"
  },
  "devDependencies": {
    "@googlemaps/js-api-loader": "^1.16.2",
    "@playwright/test": "^1.28.1",
    "@sveltejs/adapter-auto": "^2.0.0",
    "@sveltejs/kit": "^1.20.4",
    "@types/google.maps": "^3.53.5",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "autoprefixer": "^10.4.14",
    "daisyui": "^3.3.1",
    "dayjs": "^1.11.9",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-formatter-summary": "^1.1.0",
    "eslint-import-resolver-typescript": "^3.5.5",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-svelte": "^2.32.4",
    "postcss": "^8.4.27",
    "postcss-html": "^1.5.0",
    "postcss-load-config": "4.0.1",
    "prettier": "^2.8.8",
    "prettier-plugin-svelte": "^2.10.1",
    "stylelint": "^15.10.2",
    "stylelint-config-recommended": "^13.0.0",
    "stylelint-config-standard": "^34.0.0",
    "stylelint-config-tailwindcss": "^0.0.7",
    "stylelint-order": "^6.0.3",
    "svelte": "^4.0.5",
    "svelte-check": "^3.4.3",
    "svelte-collapse": "^0.1.2",
    "tailwindcss": "^3.3.3",
    "tslib": "^2.4.1",
    "typescript": "^5.0.0",
    "vite": "^4.4.2",
    "vitest": "^0.32.2"
  },
  "type": "module"
}
